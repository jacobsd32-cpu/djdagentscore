{
  "name": "x402-agent-score",
  "version": "0.1.1",
  "description": "Hono middleware to gate x402 API requests by agent reputation score",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "hono",
    "middleware",
    "x402",
    "ai-agents",
    "reputation",
    "base",
    "blockchain"
  ],
  "author": "DJD Agent Score",
  "license": "MIT",
  "homepage": "https://djdagentscore.dev",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jacobsd32-cpu/djdagentscore.git",
    "directory": "packages/x402-agent-score"
  },
  "peerDependencies": {
    "hono": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "hono": "^4.12.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
