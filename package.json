{
  "name": "djd-agent-score-service",
  "version": "1.0.0",
  "description": "Reputation scoring service for autonomous AI agents, paid via x402 micropayments",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "dev:api": "tsx watch --env-file .env src/api.ts",
    "dev:worker": "tsx watch --env-file .env src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:api": "node dist/api.js",
    "start:worker": "node dist/worker.js",
    "smoke:deploy": "node --env-file-if-exists=.env scripts/post-deploy-smoke.mjs",
    "audit:promotion": "node --env-file-if-exists=.env scripts/promotion-audit.mjs",
    "contracts:compile": "node --env-file-if-exists=.env scripts/compile-contracts.mjs",
    "contracts:check": "node --env-file-if-exists=.env scripts/compile-contracts.mjs --check",
    "contracts:bootstrap-env": "node --env-file-if-exists=.env scripts/bootstrap-evaluator-env.mjs",
    "contracts:preflight": "node --env-file-if-exists=.env scripts/preflight-evaluator-stack.mjs",
    "contracts:deploy": "node --env-file-if-exists=.env scripts/deploy-evaluator-stack.mjs",
    "contracts:publish": "node --env-file-if-exists=.env scripts/publish-evaluator-stack.mjs",
    "contracts:promote": "node --env-file-if-exists=.env scripts/promote-evaluator-stack.mjs",
    "contracts:verify": "node --env-file-if-exists=.env scripts/verify-evaluator-stack.mjs",
    "contracts:smoke": "node --env-file-if-exists=.env scripts/smoke-evaluator-stack.mjs",
    "contracts:stage": "node --env-file-if-exists=.env scripts/stage-evaluator-stack.mjs",
    "contracts:test:e2e": "vitest run tests/contracts-e2e.test.ts",
    "render:fly-config": "node scripts/render-fly-config.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@x402/core": "^2.5.0",
    "@x402/evm": "^2.5.0",
    "@x402/extensions": "^2.5.0",
    "@x402/hono": "^2.5.0",
    "better-sqlite3": "^9.6.0",
    "hono": "^4.12.7",
    "insumer-verify": "^1.1.0",
    "pino": "^10.3.1",
    "stripe": "^20.4.0",
    "uuid": "^10.0.0",
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@flydotio/dockerfile": "^0.7.10",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "ganache": "^7.9.2",
    "pino-pretty": "^13.1.3",
    "solc": "^0.8.34",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
